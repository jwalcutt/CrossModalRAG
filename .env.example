# CrossModalRAG configuration (safe placeholder values).
# Copy to `.env` and edit. `.env` is gitignored and must never contain real secrets.

# --- Storage ---
# Override the default ./data/memory.db location.
# CMRAG_DB_PATH=/absolute/path/to/memory.db

# --- Embeddings (optional; requires `pip install -e ".[embeddings]"`) ---
# CMRAG_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- LLM answer synthesis (local Ollama via HTTP; no API key needed) ---
# CMRAG_LLM_PROVIDER=ollama
# CMRAG_LLM_MODEL=gemma4
# CMRAG_LLM_BASE_URL=http://localhost:11434
# CMRAG_LLM_TIMEOUT=120
# Minimum top-hit retrieval score required before the LLM is asked to answer
# (below this the system abstains instead of speculating).
# CMRAG_MIN_EVIDENCE_SCORE=0.15

# --- Hierarchical memory extraction (local Ollama; `mem build-memory`) ---
# Model used for L1 event extraction; kept separate from synthesis so bulk
# extraction can use a faster model. Defaults to llama3.2.
# CMRAG_EXTRACT_MODEL=llama3.2
# L2 episode grouping: events in the same project within this many hours form one
# episode (session). Deterministic, no LLM. Defaults to 24.
# CMRAG_EPISODE_GAP_HOURS=24
# L3 concept clustering: minimum cosine similarity for two events to share a concept
# (requires the [embeddings] extra). Defaults to 0.60.
# CMRAG_CONCEPT_SIM_THRESHOLD=0.60

# --- Time & usage memory (Phase 4) ---
# Half-life (in days) for the usage rehearsal-strength decay: a usage event's contribution
# halves every this-many days. Usage is a separable signal (never affects ingestion
# determinism) and usage-aware ranking is opt-in. Defaults to 30.
# CMRAG_USAGE_HALFLIFE_DAYS=30
# Half-saturation point for mapping usage strength into [0,1) in the `usage` retrieval
# profile (mem ask/eval --profile usage). Higher = usage matters less. Defaults to 3.
# CMRAG_USAGE_SATURATION=3
# Real usage tracking: when on, `mem ask` logs interaction events (retrieval_hit / open, and
# accepted_answer with --accept) to the local usage_events table. OFF by default (opt-in,
# privacy-first). Only target id + event type + time are stored — never query text. Clear any
# time with `mem usage --clear`. Per-call overrides: `mem ask --track` / `--no-track` / `--accept`.
# CMRAG_USAGE_TRACKING=off

# --- Ingestion defaults (used when `mem ingest-notes` / `ingest-git` / `ingest-pdf` get no paths) ---
# Numbered, 1-based. Add as many as needed.
# OBSIDIAN_VAULT_PATH_1=/absolute/path/to/vault
# REPO_PATH_1=/absolute/path/to/repo
# PDF ingestion targets (file or directory); requires the [pdf] extra.
# PDF_PATH_1=/absolute/path/to/file-or-dir
# Image OCR ingestion targets (file or directory); requires the [ocr] extra + a local tesseract binary.
# IMAGE_PATH_1=/absolute/path/to/file-or-dir

# --- Git ingestion author filter (only commits from this author are ingested) ---
# TARGET_AUTHOR_NAME=Test User
# TARGET_AUTHOR_EMAIL=test@example.com
